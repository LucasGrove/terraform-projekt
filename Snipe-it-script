from selenium import webdriver
from selenium.webdriver.common.by import By
from selenium.webdriver.common.keys import Keys
import time
import customtkinter as ctk

# -------- CUSTOMTKINTER UI --------
ctk.set_appearance_mode("dark")
ctk.set_default_color_theme("blue")

root = ctk.CTk()
root.title("Bruger Oprettelses Værktøj")
root.geometry("500x600")

# Titel
title = ctk.CTkLabel(root, text="Opret Ny Bruger", font=ctk.CTkFont(size=24, weight="bold"))
title.pack(pady=20)

# Admin login
admin_user_label = ctk.CTkLabel(root, text="Admin Brugernavn:")
admin_user_label.pack(pady=5)
admin_user_entry = ctk.CTkEntry(root, width=300)
admin_user_entry.pack(pady=5)

admin_password_label = ctk.CTkLabel(root, text="Admin Password:")
admin_password_label.pack(pady=5)
admin_password_entry = ctk.CTkEntry(root, width=300, show="*")
admin_password_entry.pack(pady=5)

# Separator
separator = ctk.CTkLabel(root, text="─" * 40, text_color="gray")
separator.pack(pady=15)

# Ny bruger
first_label = ctk.CTkLabel(root, text="Fornavn:")
first_label.pack(pady=5)
first_entry = ctk.CTkEntry(root, width=300)
first_entry.pack(pady=5)

last_label = ctk.CTkLabel(root, text="Efternavn:")
last_label.pack(pady=5)
last_entry = ctk.CTkEntry(root, width=300)
last_entry.pack(pady=5)

username_label = ctk.CTkLabel(root, text="Brugernavn:")
username_label.pack(pady=5)
username_entry = ctk.CTkEntry(root, width=300)
username_entry.pack(pady=5)

email_label = ctk.CTkLabel(root, text="Email:")
email_label.pack(pady=5)
email_entry = ctk.CTkEntry(root, width=300)
email_entry.pack(pady=5)

password_label = ctk.CTkLabel(root, text="Password:")
password_label.pack(pady=5)
password_entry = ctk.CTkEntry(root, width=300, show="*")
password_entry.pack(pady=5)

confirm_password_label = ctk.CTkLabel(root, text="Bekræft Password:")
confirm_password_label.pack(pady=5)
confirm_password_entry = ctk.CTkEntry(root, width=300, show="*")
confirm_password_entry.pack(pady=5)

status_label = ctk.CTkLabel(root, text="", font=ctk.CTkFont(size=12))
status_label.pack(pady=10)

# -------- SELENIUM KODE --------
def run_selenium():
    # Hent værdier fra input felter
    user = admin_user_entry.get()
    password1 = admin_password_entry.get()
    first = first_entry.get()
    last = last_entry.get()
    username = username_entry.get()
    email = email_entry.get()
    password = password_entry.get()
    confirm_password = confirm_password_entry.get()

    
    # Tjek password match
    if password != confirm_password:
        status_label.configure(text="❌ Password matcher ikke!", text_color="red")
        return
    
    status_label.configure(text="Starter browser...", text_color="lightblue")
    root.update()
    
    # -------- SELENIUM SETUP --------
    driver = webdriver.Chrome()
    driver.get("http://10.132.128.102:8050/")  # automatically redirects to login
    
    time.sleep(1)
    
    status_label.configure(text="Logger ind...", text_color="lightblue")
    root.update()
    
    # -------- LOGIN WITH ADMIN ACCOUNT --------
    driver.find_element(By.ID, "username").send_keys(user)
    driver.find_element(By.ID, "password").send_keys(password1)
    login_btn = driver.find_element(By.XPATH, "//button[contains(text(),'Login')]")
    login_btn.click()
    
    time.sleep(1)
    
    # --- Klik på 'Create New' dropdown ---
    create_new_btn = driver.find_element(By.XPATH, "//a[contains(text(),'Create New')]")
    create_new_btn.click()
    time.sleep(0.5)  # vent på dropdown
    
    # --- Klik på 'User' ---
    user_btn = driver.find_element(By.XPATH, "//a[contains(@href,'/users/create')]")
    user_btn.click()
    time.sleep(1)
    
    if "/users/create" not in driver.current_url:
        status_label.configure(text="❌ Not on user creation page - aborting", text_color="red")
        driver.quit()
        return
    
    
    status_label.configure(text="Udfylder formular...", text_color="lightblue")
    root.update()
    
    # -------- FILL NEW USER FORM --------
    driver.find_element(By.ID, "first_name").send_keys(first)
    driver.find_element(By.ID, "last_name").send_keys(last)
    driver.find_element(By.ID, "username").send_keys(username)
    driver.find_element(By.ID, "email").send_keys(email)
    driver.find_element(By.ID, "password").send_keys(password)
    confirm_input = driver.find_element(By.ID, "password_confirm")
    confirm_input.send_keys(confirm_password)
    
    # --- Marker 'This user can login' checkbox hvis ikke allerede markeret ---
    checkbox = driver.find_element(By.ID, "activated")
    if not checkbox.is_selected():
        checkbox.click()
    time.sleep(1)

     # --- Marker 'This user can login' checkbox hvis ikke allerede markeret ---
    checkbox = driver.find_element(By.ID, "email_user_checkbox")
    if not checkbox.is_selected():
        checkbox.click()
    time.sleep(1)
    
    driver.execute_script("""
    document.querySelectorAll('input, select').forEach(el => el.dispatchEvent(new Event('change')));
    """)
    
    status_label.configure(text="Gemmer bruger...", text_color="lightblue")
    root.update()
    
    # --- Klik på Save knappen ---
    save_btn = driver.find_element(By.CSS_SELECTOR, "button.btn.btn-primary.pull-right")
    save_btn.click()
    time.sleep(1)
    if "/hardware" in driver.current_url:
        status_label.configure(text="⚠️ Redirected to Assets page - skipping tagging", text_color="orange")
        driver.get("http://10.132.128.102:8050/users")  # Tilbage til user oversigt
        time.sleep(1)
    
    status_label.configure(text="✅ User created successfully!", text_color="green")
    time.sleep(1)
    clear_user_fields()
    driver.quit()
    

# Knap til at starte
create_button = ctk.CTkButton(root, text="Opret Bruger", command=run_selenium, 
                            font=ctk.CTkFont(size=16, weight="bold"), height=40)
def clear_user_fields():
    # Ryd kun FELTERNE til ny bruger
    first_entry.delete(0, 'end')
    last_entry.delete(0, 'end')
    username_entry.delete(0, 'end')
    email_entry.delete(0, 'end')
    password_entry.delete(0, 'end')
    confirm_password_entry.delete(0, 'end')
   

    # Sæt cursor tilbage til første felt
    first_entry.focus()
create_button.pack(pady=20)

root.mainloop()
